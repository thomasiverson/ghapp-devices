# ── Broker connection ───────────────────────────────────
# Must match the broker's PORT value
BROKER_URL=http://localhost:4041

# ── Auth mode: "api-key" or "entra-id" ─────────────────
AUTH_METHOD=api-key

# ── API key authentication ─────────────────────────────
# Must match one of the keys in the broker's BROKER_API_KEYS
BROKER_API_KEY=your-device-api-key-1

# ── Entra ID authentication (optional, certificate-based) ──
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-device-app-client-id
AZURE_CLIENT_CERTIFICATE_PATH=./device-cert.pem

# The audience to request when acquiring an Entra ID token.
# This should match the broker's ENTRA_CLIENT_ID.
ENTRA_BROKER_AUDIENCE=your-broker-app-client-id

# ── Target repository for demo operations ──────────────
# The repo where the GitHub App is installed
GITHUB_OWNER=your-org
GITHUB_REPO=your-test-repo

# ── Dashboard port (used by `npm run demo`) ────────────
PORT=4040
