# ── GitHub App credentials ──────────────────────────────
# Get these from: https://github.com/organizations/<ORG>/settings/apps/<APP>
GITHUB_APP_ID=123456
GITHUB_INSTALLATION_ID=78901234
GITHUB_PRIVATE_KEY_PATH=./private-key.pem

# ── Broker configuration ───────────────────────────────
PORT=4041

# ── API key authentication ─────────────────────────────
# Comma-separated list of valid device API keys.
# Generate your own keys (e.g. `openssl rand -hex 32`) and share
# the same values with the device client's BROKER_API_KEY.
BROKER_API_KEYS=your-device-api-key-1,your-device-api-key-2

# ── Entra ID authentication (optional) ────────────────
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-broker-app-client-id
