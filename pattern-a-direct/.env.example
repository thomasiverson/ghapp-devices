# ── GitHub App credentials ──────────────────────────────
# Get these from: https://github.com/organizations/<ORG>/settings/apps/<APP>
GITHUB_APP_ID=123456
GITHUB_INSTALLATION_ID=78901234
GITHUB_PRIVATE_KEY_PATH=./private-key.pem

# ── Target repository for demo operations ──────────────
# The repo where the GitHub App is installed
GITHUB_OWNER=your-org
GITHUB_REPO=your-test-repo

# ── Dashboard port (used by `npm run demo`) ────────────
PORT=3030
